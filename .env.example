# Variables de entorno — copia a `.env.local`

# URL base de la API Cobru (sandbox por defecto)
COBRU_API_URL=https://dev.cobru.co

# URL para categorías/subcategorías (usa el mismo ambiente que COBRU_API_URL)
COBRU_PROD_URL=https://prod.cobru.co

# Credenciales Cobru (obligatorias — solo en servidor, nunca en el frontend)
COBRU_API_KEY=tu_api_key_aqui
COBRU_REFRESH_TOKEN=tu_refresh_token_aqui

# Identificador de marca whitelabel asignado por Cobru
COBRU_BRAND=TRIXEL

# Endpoint de subida de archivos en Cobru (confirmar con tu equipo Cobru)
COBRU_UPLOAD_URL=https://dev.cobru.co/upload/
